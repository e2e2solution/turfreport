# Copy to server/.env and fill in your values (never commit .env)

PORT=3001
JWT_SECRET=change-this-secret

# Staff login
AUTH_USERNAME=sebi
AUTH_PASSWORD=shyju

# MongoDB Atlas — replace <db_password> with your real password
# Atlas → Network Access → allow 0.0.0.0/0 so cloud server can connect
MONGODB_URI=mongodb+srv://4e2esolution_db_user:<db_password>@cluster0.d9avz1m.mongodb.net/?appName=Cluster0
MONGODB_DB=vsh_owner

# Owner mobile app PIN (share only with owner)
OWNER_PIN=123

# --- Local PC staff app: push reports to cloud when direct Mongo fails ---
# Set CLOUD_SYNC_URL to your deployed app URL (e.g. https://vsh-sports-hub.onrender.com)
# Set OWNER_SYNC_KEY to the SAME secret on cloud server (Render env → OWNER_SYNC_KEY)
# CLOUD_SYNC_URL=https://your-app.onrender.com
# OWNER_SYNC_KEY=generate-a-long-random-string
